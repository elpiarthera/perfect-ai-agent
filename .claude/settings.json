{
  "permissions": {
    "allow": [
      "*",
      "mcp__vantage-memory__get_diary"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 /root/coding/perfect-ai-agent/.claude/hooks/session-start-phi.py"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "mcp__vantage-peers__send_message",
        "hooks": [
          {
            "type": "command",
            "command": "python3 /root/coding/perfect-ai-agent/.claude/hooks/enforce-no-task-in-message.py",
            "timeout": 5
          }
        ]
      }
    ]
  },
  "additionalDirectories": [
    "/root/coding/elpi-corp"
  ]
}
