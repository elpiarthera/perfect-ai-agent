{
  "permissions": {
    "allow": [
      "Read(**)",
      "Write(**)",
      "Edit(**)",
      "Bash(*)",
      "Agent(*)",
      "Glob(*)",
      "Grep(*)",
      "mcp__vantage-memory__*",
      "mcp__convex__*",
      "mcp__composio__*",
      "mcp__firecrawl__*",
      "mcp__exa__*"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"/home/elpi/coding/perfect-ai-agent/.claude/hooks/session-start-phi.py\""
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "bash hooks/enforce-background-agents.sh"
          }
        ]
      }
    ]
  }
}